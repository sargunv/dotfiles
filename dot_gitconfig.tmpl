# Git Configuration
#
# This file is managed by chezmoi. To add personal overrides without
# modifying this file, create ~/.gitconfig.local — it is included
# at the bottom.

# User
[user]
	name = {{ .full_name }}
	email = {{ .github_username }}@users.noreply.github.com
[core]
	excludesfile = ~/.gitignore_global  # shared ignore patterns across all repos
[init]
	defaultBranch = main                # use 'main' instead of 'master' for new repos
[credential "https://github.com"]
	helper = !gh auth git-credential    # authenticate via gh cli
[credential "https://gist.github.com"]
	helper = !gh auth git-credential    # authenticate via gh cli

# Improved defaults
[branch]
	sort = -committerdate               # list most recently committed branches first
[push]
	autoSetupRemote = true              # auto-track remote branch on first push
	useForceIfIncludes = true           # prevent force-push if remote has unseen commits
[pull]
	rebase = true                       # rebase local commits on top of upstream changes
[rebase]
	autoStash = true                    # stash dirty worktree before rebase, then pop after
[diff]
	algorithm = histogram               # better diff output for moved blocks of code
[merge]
	conflictstyle = zdiff3              # show base, ours, and theirs in conflict markers

# Delta
[core]
	pager = sh -c '[ -z "$NO_FANCY_SHELL" ] && delta || [ -z "$PAGER" ] && less -RF --mouse || $PAGER'
[interactive]
	diffFilter = sh -c '[ -z "$NO_FANCY_SHELL" ] && delta --color-only || cat'
[delta]
	navigate = true                     # enable n/N keybindings to jump between diff sections

# Local overrides
[include]
	path = ~/.gitconfig.local
