{
  "languages": {
    "Markdown": {
      "soft_wrap": "none",
    },
  },
  "agent": {
    "tool_permissions": {
      "tools": {
        "fetch": {
          "default": "allow",
        },
        "terminal": {
          "default": "allow",
        },
      },
    },
    "default_model": {
      "effort": "high",
      "provider": "openai-subscribed",
      "model": "gpt-5.5",
      "enable_thinking": true,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "language_models": {
    "openai_compatible": {
      "Z.AI Coding Plan": {
        "api_url": "https://api.z.ai/api/coding/paas/v4",
        "available_models": [
          {
            "name": "glm-5.2",
            "max_tokens": 1000000,
            "max_output_tokens": 131072,
            "reasoning_effort": "xhigh",
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": true,
              "prompt_cache_key": true,
              "chat_completions": true,
              "interleaved_reasoning": false,
              "max_tokens_parameter": true,
            },
          },
        ],
      },
    },
    "opencode": {
      "show_free_models": false,
      "show_zen_models": false,
    },
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark",
  },
}
