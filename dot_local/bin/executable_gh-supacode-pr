#!/bin/zsh
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
usage: gh-supacode-pr [<number> | <url> | <branch>] [flags]

Create or focus a Supacode worktree for a GitHub pull request.

flags:
  -b, --branch <name>        Local branch name to use
  -R, --repo <owner/repo>    Select another GitHub repository
  -h, --help                 Show help
EOF
}

die() {
  print -r -- "gh-supacode-pr: $*" >&2
  exit 1
}

strip_ansi() {
  sed $'s/\x1b\\[[0-9;]*m//g'
}

urldecode() {
  perl -Mstrict -Mwarnings -e '
    my $s = shift // "";
    $s =~ s/%([0-9A-Fa-f]{2})/chr hex $1/eg;
    print $s;
  ' "$1"
}

sanitize_name() {
  print -r -- "$1" | sed 's#[/[:space:]]#-#g; s#[^A-Za-z0-9._-]#-#g; s#--*#-#g; s#^-##; s#-$##'
}

repo_arg=()
selected_repo=""
target=""
local_branch=""

while (($# > 0)); do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    -R|--repo)
      (($# >= 2)) || die "$1 requires a value"
      repo_arg=("--repo" "$2")
      selected_repo="$2"
      shift 2
      ;;
    --repo=*)
      repo_arg=("--repo" "${1#*=}")
      selected_repo="${1#*=}"
      shift
      ;;
    -b|--branch)
      (($# >= 2)) || die "$1 requires a value"
      local_branch="$2"
      shift 2
      ;;
    --branch=*)
      local_branch="${1#*=}"
      shift
      ;;
    --)
      shift
      break
      ;;
    -*)
      die "unknown option: $1"
      ;;
    *)
      if [[ -n "$target" ]]; then
        die "unexpected argument: $1"
      fi
      target="$1"
      shift
      ;;
  esac
done

if (($# > 0)); then
  if [[ -n "$target" ]]; then
    die "unexpected argument: $1"
  fi
  target="$1"
fi

[[ -n "$target" ]] || die "a pull request number, URL, or branch is required"
command -v gh >/dev/null 2>&1 || die "gh is not installed"
command -v supacode >/dev/null 2>&1 || die "supacode is not installed"
command -v git >/dev/null 2>&1 || die "git is not installed"

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || die "not inside a git repository"
repo_root="${repo_root:A}"
repo_root_slash="${repo_root%/}/"

local_repo="$(gh repo view --json nameWithOwner --jq '.nameWithOwner')"
if [[ -n "$selected_repo" ]]; then
  current_repo="$(gh repo view "$selected_repo" --json nameWithOwner --jq '.nameWithOwner')"
else
  current_repo="$local_repo"
fi
if [[ "$current_repo" != "$local_repo" ]]; then
  die "selected repository is $current_repo, but the current checkout is $local_repo"
fi

if [[ "$target" == https://github.com/*/*/pull/* || "$target" == http://github.com/*/*/pull/* ]]; then
  url_repo="$(print -r -- "$target" | sed -E 's#^https?://github.com/([^/]+/[^/]+)/pull/.*$#\1#')"
  if [[ "$url_repo" != "$current_repo" ]]; then
    die "pull request URL is for $url_repo, but the current checkout is $current_repo"
  fi
fi

pr_row="$(gh pr view "$target" "${repo_arg[@]}" \
  --json number,headRefName,baseRefName,headRepository \
  --jq '[.number, .headRefName, .baseRefName, .headRepository.nameWithOwner] | @tsv')"

IFS=$'\t' read -r pr_number head_ref base_ref head_repo <<< "$pr_row"
[[ -n "$pr_number" && -n "$head_ref" && -n "$base_ref" && -n "$head_repo" ]] || die "could not resolve pull request: $target"

if [[ -z "$local_branch" ]]; then
  local_branch="$head_ref"
fi

repo_id=""
while IFS= read -r encoded_id; do
  [[ -n "$encoded_id" ]] || continue
  decoded_id="$(urldecode "$encoded_id")"
  if [[ "$decoded_id" == "$repo_root_slash" ]]; then
    repo_id="$encoded_id"
    break
  fi
done < <(supacode repo list | strip_ansi)

if [[ -z "$repo_id" ]]; then
  supacode repo open "$repo_root"
  while IFS= read -r encoded_id; do
    [[ -n "$encoded_id" ]] || continue
    decoded_id="$(urldecode "$encoded_id")"
    if [[ "$decoded_id" == "$repo_root_slash" ]]; then
      repo_id="$encoded_id"
      break
    fi
  done < <(supacode repo list | strip_ansi)
fi

[[ -n "$repo_id" ]] || die "could not find Supacode repository for $repo_root"

while IFS= read -r worktree_id; do
  [[ -n "$worktree_id" ]] || continue
  worktree_path="$(urldecode "$worktree_id")"
  [[ -d "$worktree_path/.git" || -f "$worktree_path/.git" ]] || continue
  branch="$(git -C "$worktree_path" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
  if [[ "$branch" == "$local_branch" ]]; then
    supacode worktree focus --worktree "$worktree_id"
    print -r -- "Focused existing Supacode worktree for $current_repo#$pr_number ($local_branch)."
    exit 0
  fi
done < <(supacode worktree list | strip_ansi)

base="origin/$head_ref"
if [[ "$head_repo" != "$current_repo" ]]; then
  fetch_repo="$(gh repo view "$head_repo" --json sshUrl,url --jq '.sshUrl // .url')"
  [[ -n "$fetch_repo" ]] || die "could not resolve fetch URL for $head_repo"
  owner="${head_repo%%/*}"
  remote_ref="refs/remotes/${owner}/${head_ref}"
  git -C "$repo_root" fetch "$fetch_repo" "+refs/heads/${head_ref}:${remote_ref}"
  base="${owner}/${head_ref}"
fi

worktree_name="$(sanitize_name "pr-${pr_number}-${local_branch}")"
supacode repo worktree-new \
  --repo "$repo_id" \
  --branch "$local_branch" \
  --base "$base" \
  --name "$worktree_name" \
  --fetch

while IFS= read -r worktree_id; do
  [[ -n "$worktree_id" ]] || continue
  worktree_path="$(urldecode "$worktree_id")"
  [[ -d "$worktree_path/.git" || -f "$worktree_path/.git" ]] || continue
  branch="$(git -C "$worktree_path" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
  if [[ "$branch" == "$local_branch" ]]; then
    supacode worktree focus --worktree "$worktree_id"
    break
  fi
done < <(supacode worktree list | strip_ansi)

print -r -- "Created Supacode worktree for $current_repo#$pr_number ($local_branch)."
