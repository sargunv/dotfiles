#!/bin/sh
set -eu

{{ if eq .chezmoi.os "darwin" -}}
subnet="{{ .parallels_subnet }}"
out="$HOME/.ssh/config.d/parallels-vms"
tmp=""

usage() {
  echo "usage: generate-parallels-ssh-config" >&2
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage
      exit 2
      ;;
  esac
done

fingerprint_for() {
  _ip=$1
  ssh-keyscan -T 2 -t ed25519 "$_ip" 2>/dev/null \
    | ssh-keygen -lf - -E sha256 2>/dev/null \
    | awk '{print $2}'
}

mkdir -p "$HOME/.ssh/config.d"
tmp=$(mktemp)
trap 'rm -f "$tmp"' EXIT

{
  echo "# Generated by generate-parallels-ssh-config; do not edit."
  echo "# Refresh: generate-parallels-ssh-config"
  echo

  vm_specs=$(cat <<'EOF'
{{ range $name, $vm := .ssh_hosts -}}
{{ $name }}|{{ $vm.user }}|{{ $vm.host_key }}
{{ end }}
EOF
)

  printf '%s\n' "$vm_specs" | while IFS='|' read -r name user host_key; do
    [ -n "$name" ] || continue
    ip=""

    for last_octet in $(seq 2 254); do
      candidate="${subnet}.${last_octet}"
      if ! nc -z -G 1 "$candidate" 22 2>/dev/null; then
        continue
      fi

      fingerprint=$(fingerprint_for "$candidate")
      if [ "$fingerprint" = "$host_key" ]; then
        ip="$candidate"
        break
      fi
    done

    if [ -z "$ip" ]; then
      echo "# ${name}: not found on ${subnet}.0/24 (${host_key})" >&2
      continue
    fi

    printf '%s\n' \
      "Host ${name} ${ip}" \
      "  HostName ${ip}" \
      "  User ${user}" \
      "  IdentityFile ~/.ssh/id_ed25519" \
      "  IdentitiesOnly yes" \
      ""
  done
} > "$tmp"

mv "$tmp" "$out"
chmod 644 "$out"
{{ else -}}
echo "generate-parallels-ssh-config is only configured for macOS." >&2
exit 1
{{ end -}}
